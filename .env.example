# === MQTT Configuration ===
# Public Meshtastic MQTT broker or your own — e.g. mqtt.meshtastic.org
MQTT_HOST=mqtt.example.com
MQTT_PORT=1883
MQTT_USER=your_mqtt_user
MQTT_PASS=your_mqtt_password
MQTT_TOPICS=msh/US/2/e/#

# === Meshtastic Encryption ===
# Default Meshtastic public channel key. Override if your mesh uses a custom PSK.
MESH_KEY=1PG7OiApB1nwvP+rz05pAQ==

# === Discord Bot ===
# Get your token from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here
# Channel ID for anomaly alerts (right-click channel -> Copy Channel ID)
DISCORD_ALERT_CHANNEL_ID=0
# Optional: Guild/server ID for faster slash command sync during development
DISCORD_GUILD_ID=

# === Web Dashboard ===
WEB_HOST=0.0.0.0
WEB_PORT=5000
# Public URL for links in Discord embeds (your server's public address)
WEB_BASE_URL=http://localhost:5000

# Shared secret required by /proxy/* endpoints. Generate with: openssl rand -hex 32
PROXY_SECRET=

# === Mesh Center Coordinates ===
# Used for weather data fetching — set to your mesh network's approximate center
MESH_CENTER_LAT=41.0
MESH_CENTER_LON=-75.9

# === Weather ===
# Polling interval in seconds (default: 900 = 15 minutes)
WEATHER_INTERVAL_SEC=900

# === Shadow Analysis Grid ===
GRID_CELL_SIZE_M=100
GRID_PADDING_KM=2.0
MAX_NODE_RANGE_KM=15.0
COVERAGE_RECALC_SEC=600
SHADOW_THRESHOLD=0.6
MIN_DEAD_ZONE_CELLS=5

# === Elevation API ===
ELEVATION_API_URL=https://api.opentopodata.org/v1/srtm90m
ELEVATION_BATCH_SIZE=100
ELEVATION_RATE_LIMIT_SEC=1.0

# === Coverage Snapshots ===
SNAPSHOT_INTERVAL_SEC=3600

# === Anomaly Detection ===
ANOMALY_CHECK_INTERVAL_SEC=300
ANOMALY_SNR_STDDEV=2.0
ANOMALY_MIN_OBS=20
ANOMALY_LOST_LINK_HOURS=6

# === Logging ===
LOG_LEVEL=INFO
